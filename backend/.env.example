PROJECT_NAME=工业设备预测性维护系统
MYSQL_URL=mysql+pymysql://root:123123@127.0.0.1:3306/pdm
REDIS_URL=redis://127.0.0.1:6379/0
TSDB_URL=postgresql://pdm:123123@127.0.0.1:5432/pdm_tsdb
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_TELEMETRY_RAW_TOPIC=factory.telemetry.raw
KAFKA_TELEMETRY_CLEANED_TOPIC=factory.telemetry.cleaned
KAFKA_TELEMETRY_INVALID_TOPIC=factory.telemetry.invalid
KAFKA_FEATURES_WINDOWED_TOPIC=factory.features.windowed
KAFKA_PREDICTIONS_CREATED_TOPIC=factory.predictions.created
KAFKA_WARNINGS_CREATED_TOPIC=factory.warnings.created
KAFKA_RAW_GROUP_ID=pdm-raw-telemetry-cleaner
KAFKA_CLEANED_GROUP_ID=pdm-cleaned-telemetry-writer
KAFKA_FEATURE_GROUP_ID=pdm-feature-window-builder
KAFKA_INFERENCE_GROUP_ID=pdm-async-inference
FEATURE_WINDOW_READING_LIMIT=120
WARNING_SUPPRESSION_SECONDS=60
MQTT_BROKER_HOST=127.0.0.1
MQTT_BROKER_PORT=1883
MQTT_TELEMETRY_TOPIC=factory/+/workshop/+/line/+/machine/+/telemetry
MQTT_CLIENT_ID=pdm-mqtt-to-kafka
MQTT_TO_KAFKA_ENABLED=true
RAW_TELEMETRY_CONSUMER_ENABLED=true
CLEANED_TELEMETRY_CONSUMER_ENABLED=true
FEATURE_CONSUMER_ENABLED=true
INFERENCE_CONSUMER_ENABLED=true
# 普通 uvicorn 启动默认关闭；仅在已启动全部中间件时显式开启完整模拟链路。
SIMULATION_AUTO_START=false
SIMULATION_CONTROL_API_ENABLED=true
SIMULATION_MODEL_BOOTSTRAP_ENABLED=true
SIMULATION_MODEL_DATASET_PATH=../ai4i2020.csv
SIMULATION_DEVICE_COUNT=6
SIMULATION_MODE=degrading
SIMULATION_INTERVAL_SECONDS=1.0
SIMULATION_START_DELAY_SECONDS=2.0
